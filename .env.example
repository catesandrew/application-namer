# ============================================================
# Application Namer — Environment Configuration
# Copy this file to .env.local and fill in values as needed.
# At least one AI provider key is required for suggestions.
# ============================================================

# --- AI Provider Keys ---
# Anthropic Claude — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- GitHub Token (optional) ---
# Increases GitHub search rate limit from ~10 to ~30 req/min.
# Create a token at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# --- MCP Bridge Server URLs ---
# Used to forward suggestion requests to locally-running AI bridge servers.
# Defaults shown below; only needed if running local MCP bridges.
MCP_CLAUDE_URL=http://localhost:8960
MCP_CODEX_URL=http://localhost:8961
MCP_COPILOT_URL=http://localhost:8962
